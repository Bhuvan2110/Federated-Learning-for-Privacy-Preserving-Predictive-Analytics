# ══════════════════════════════════════════════════════════════════════════
#  Training Models v4.0 — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=tm_db
POSTGRES_USER=tm_user
POSTGRES_PASSWORD=tm_pass          # Change in production!

# Full connection string (used by the Flask app directly)
# When running via docker-compose, host is "postgres" (service name)
# When running locally without Docker, host is "localhost"
DATABASE_URL=postgresql://tm_user:tm_pass@localhost:5432/tm_db

# ── Database pool settings ─────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false                      # Set to "true" to log all SQL (dev only)

# ── SQLite fallback (dev / CI without Postgres) ────────────────────────────
# USE_SQLITE_FALLBACK=true         # Uncomment to use SQLite instead of Postgres

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_ENV=development              # Use "production" in prod

# ── Celery / Redis (Day 2) ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_ASYNC_ENABLED=true        # set to "false" to run training synchronously (no Redis needed)
CELERY_TASK_SOFT_TIME_LIMIT=600  # seconds before SoftTimeLimitExceeded
CELERY_TASK_TIME_LIMIT=660       # hard kill after this many seconds

# ── gRPC Server (Day 5) ────────────────────────────────────────────────────
GRPC_PORT=50051
GRPC_MAX_WORKERS=10
GRPC_REFLECTION=false   # set to "true" to enable grpcurl/BloomRPC introspection

# ── MLflow Tracking (Day 6) ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000   # or ./mlruns for local file store
MLFLOW_EXPERIMENT_NAME=training-models
MLFLOW_ENABLED=true                         # set to "false" to disable tracking
MLFLOW_REGISTER_MODELS=true                 # set to "false" to skip model registry
MLFLOW_DB=mlflow_db                         # separate Postgres DB for MLflow backend

# ── Prometheus / Grafana (Day 7) ───────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc  # required for gunicorn multiprocess
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme   # Change in production!

# ── Authentication / OAuth 2.0 (Day 8) ────────────────────────────────────
AUTH_ENABLED=true                 # set to "false" to disable auth entirely
AUTH_OPTIONAL=false               # set to "true" for local dev without tokens
JWT_SECRET_KEY=CHANGE_ME_IN_PROD  # HS256 signing secret (min 32 chars)
JWT_ALGORITHM=HS256               # HS256 (default) or RS256 for OIDC
JWT_ACCESS_TOKEN_TTL=900          # access token lifetime in seconds (15 min)
JWT_REFRESH_TOKEN_TTL=604800      # refresh token lifetime in seconds (7 days)
JWT_REDIS_BLOCKLIST_DB=2          # Redis DB index for token revocation

# ── Audit logging (Day 8) ─────────────────────────────────────────────────
AUDIT_ENABLED=true
AUDIT_HASH_CHAIN=true             # set to "false" to skip hash chaining (faster)
